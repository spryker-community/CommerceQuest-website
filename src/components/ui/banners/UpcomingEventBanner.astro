---
interface Props {
  title: string;
  date: string;
  time: string;
  location: string;
  url: string;
  topics?: string[];
}

const { title, date, time, location, url, topics = [] } = Astro.props;
---
<a href={url} class="group block rounded-xl bg-neutral-100 dark:bg-[#0A1628] shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden p-10 h-full flex flex-col items-center justify-center gap-5">

  <!-- Calendar icon -->
  <div class="text-center bg-blue-500 dark:bg-blue-600 rounded-lg overflow-hidden w-16">
    <div class="text-xs uppercase tracking-wide text-blue-100 bg-blue-600 dark:bg-blue-700 py-1">
      {new Date(date).toLocaleString('en-US', { month: 'short' })}
    </div>
    <div class="text-2xl font-bold text-white py-2">
      {new Date(date).getDate()}
    </div>
  </div>

  <div class="text-center">
    <p class="text-xs font-semibold uppercase tracking-wide text-blue-500 dark:text-blue-400 mb-2">Upcoming Event</p>
    <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-200 leading-tight group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors duration-200">
      {title}
    </h3>
    <div class="flex flex-wrap justify-center gap-x-4 gap-y-1 mt-3 text-sm text-neutral-500 dark:text-neutral-400">
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        {time}
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        {location}
      </span>
    </div>
  </div>

  {topics.length > 0 && (
    <div class="flex flex-wrap justify-center gap-2">
      {topics.map((topic) => (
        <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-blue-500/10 dark:bg-blue-400/10 text-blue-600 dark:text-blue-400">
          {topic}
        </span>
      ))}
    </div>
  )}

  <span class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-blue-500 hover:bg-blue-600 text-white font-medium transition-colors duration-200">
    View Details & Join →
  </span>
</a>
