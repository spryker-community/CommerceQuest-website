---

<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://commercequest.space/videos",
    "url": "https://commercequest.space/videos",
    "name": "Spryker Community Videos | CommerceQuest",
    "description": "A curated collection of Spryker hackathons, user groups, AI talks, and community videos.",
    "isPartOf": {
      "@type": "WebSite",
      "url": "https://commercequest.space/",
      "name": "CommerceQuest",
      "description": "Commerce Resources for the driven Spryker, Propel & Oryx developer."
    },
    "inLanguage": "en-US"
  }}
>
  <MainSection
    title="Spryker Community Videos"
    description="Explore our curated collection of Spryker hackathons, user groups, AI talks, and community videos — all in one place."
    btnExists={false}
  />

  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 2xl:max-w-full">
    {categories.map((category) => (
      <div class="mb-16">
        <h2 class="mb-8 text-3xl font-bold text-neutral-800 dark:text-neutral-200">
          {category.name}
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {category.videos.map((video) => (
            <a
              href={`https://www.youtube.com/watch?v=${video.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group block overflow-hidden rounded-xl bg-neutral-100 shadow-md transition hover:shadow-lg dark:bg-[#0A1628]"
            >
              <div class="relative aspect-video w-full overflow-hidden">
                <img
                  src={`https://img.youtube.com/vi/${video.id}/hqdefault.jpg`}
                  alt={video.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 flex items-center justify-center opacity-80 transition group-hover:opacity-100">
                  <div class="rounded-full bg-black/60 p-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-8 w-8 text-white"
                    >
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-4">
                <h3 class="line-clamp-2 text-sm font-semibold text-neutral-800 dark:text-neutral-200">
                  {video.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</MainLayout>
